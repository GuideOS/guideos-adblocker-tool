    def start_update_thread(self):
        def worker():
            log.info("worker: gestartet")
            try:
                self.do_update()
                log.info("worker: do_update fertig")
            except Exception:
                log.error(f"worker: EXCEPTION:\n{traceback.format_exc()}")
            GLib.idle_add(self.refresh_update_status_label)
            GLib.idle_add(self.update_custom_count)
            log.info("worker: idle_add gesetzt – Thread endet")

        t = threading.Thread(target=worker, name="UpdateThread", daemon=True)
        t.start()
        log.info(f"start_update_thread: gestartet id={t.ident}")

    def do_update(self):
        log.info("do_update: lese active_lists")
        active_lists = []
        if os.path.exists(self.app.ACTIVE_LISTS_FILE):
            with open(self.app.ACTIVE_LISTS_FILE, 'r') as f:
                active_lists = [l.strip() for l in f if l.strip()]
        log.info(f"do_update: active_lists={active_lists}")

        all_lists = self.app.get_all_lists()
        has_lists  = any(k in active_lists for k in all_lists)
        has_custom = "CUSTOM" in active_lists and os.path.exists(self.app.CUSTOM_FILE)

        if not has_lists and not has_custom:
            log.info("do_update: keine aktiven Listen – nichts zu tun")
            return

        tmp = tempfile.NamedTemporaryFile(mode='w', delete=False, suffix='.hosts')
        log.info(f"do_update: temp-Datei: {tmp.name}")

        with open(self.app.BACKUP_FILE, 'r') as f:
            tmp.write(f.read())
        tmp.write(f"\n# Blocklisten – Aktualisiert am {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n\n")

        for key in all_lists:
            if key not in active_lists:
                continue
            url = all_lists[key]
            log.info(f"do_update: lade '{key}'")
            try:
                resp    = requests.get(url, timeout=30)
                content = resp.text
                log.info(f"do_update: '{key}' OK ({len(content)} Zeichen)")
                if re.search(r'^(0\.0\.0\.0|127\.0\.0\.1|::1)', content, re.MULTILINE):
                    for line in content.splitlines():
                        if re.match(r'^(0\.0\.0\.0|127\.0\.0\.1|::1)', line):
                            line = re.sub(r'^127\.0\.0\.1', '0.0.0.0', line)
                            if not line.startswith('#'):
                                tmp.write(line + '\n')
                else:
                    for line in content.splitlines():
                        line = line.strip()
                        if line and not line.startswith('#'):
                            tmp.write(f"0.0.0.0 {line}\n")
            except Exception as e:
                log.error(f"do_update: Fehler bei '{key}': {e}")

        if has_custom:
            log.info("do_update: füge Custom-Einträge hinzu")
            tmp.write("\n# GuideOS-Adblocker – Eigene Einträge\n")
            with open(self.app.CUSTOM_FILE, 'r') as f:
                tmp.write(f.read())

        tmp.close()

        log.info("do_update: schreibe /etc/hosts via sudo")
        rc, _, err = run_privileged(f'sort -u {tmp.name} > /etc/hosts')
        if rc != 0:
            if err == "AUTH_EXPIRED":
                log.error("Authentifizierung abgelaufen")
                GLib.idle_add(self.show_info, "Authentifizierung erforderlich", 
                            "Die sudo-Session ist abgelaufen. Bitte starten Sie das Programm neu.")
            else:
                log.error(f"do_update: /etc/hosts schreiben fehlgeschlagen: {err}")
                GLib.idle_add(self.show_info, "Fehler", f"Konnte /etc/hosts nicht aktualisieren:\n{err}")
        os.unlink(tmp.name)

        log.info("do_update: flush DNS")
        run_privileged('systemd-resolve --flush-caches 2>/dev/null || resolvectl flush-caches 2>/dev/null || true')

        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        ts_tmp = tempfile.NamedTemporaryFile(mode='w', delete=False)
        ts_tmp.write(timestamp)
        ts_tmp.close()
        run_privileged(f'mv {ts_tmp.name} {self.app.LAST_UPDATE_FILE}')
        log.info(f"do_update: fertig – {timestamp}")

