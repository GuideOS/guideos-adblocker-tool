        desc_label = Gtk.Label()
        desc_label.set_markup("<small>Fügen Sie URLs von Blocklisten hinzu (z.B. von GitHub, Pastebin, etc.)</small>")
        desc_label.set_xalign(0)
        desc_label.set_margin_bottom(12)
        desc_label.set_margin_start(12)
        desc_label.set_margin_end(12)
        desc_label.add_css_class("dim-label")
        main_box.append(desc_label)

        scrolled = Gtk.ScrolledWindow()
        scrolled.set_vexpand(True)

        self.list_box = Gtk.ListBox()
        self.list_box.set_selection_mode(Gtk.SelectionMode.NONE)
        self.list_box.add_css_class("boxed-list")
        self.list_box.set_margin_top(0)
        self.list_box.set_margin_bottom(12)
        self.list_box.set_margin_start(12)
        self.list_box.set_margin_end(12)

        self.refresh_list()

        scrolled.set_child(self.list_box)
        main_box.append(scrolled)

    def refresh_list(self):
        """Aktualisiert die Anzeige der Benutzerlisten"""
        # Bestehende Einträge entfernen
        for child in self.list_box.observe_children():
            self.list_box.remove(child)

        if not self.app.user_lists:
            empty_label = Gtk.Label()
            empty_label.set_markup("<i>Keine eigenen Blocklisten vorhanden</i>")
            empty_label.set_margin_top(24)
            empty_label.set_margin_bottom(24)
            empty_label.add_css_class("dim-label")
            self.list_box.append(empty_label)
            return

        for name, url in self.app.user_lists.items():
            row = Adw.ActionRow()
            row.set_title(name)
            row.set_subtitle(url)
            
            delete_btn = Gtk.Button(label="Entfernen")
            delete_btn.add_css_class("destructive-action")
            delete_btn.connect("clicked", lambda x, n=name: self.on_delete_list(n))
            row.add_suffix(delete_btn)
            
            self.list_box.append(row)

    def on_add_list(self, button):
        """Dialog zum Hinzufügen einer neuen Blockliste"""
        dialog = Adw.AlertDialog(
            heading="Neue Blockliste hinzufügen",
            body="Geben Sie einen Namen und die URL der Blockliste ein:"
        )
        dialog.add_response("cancel", "Abbrechen")
        dialog.add_response("add", "Hinzufügen")
        dialog.set_response_appearance("add", Adw.ResponseAppearance.SUGGESTED)
        dialog.set_default_response("add")

        # Name Eingabe
        name_entry = Gtk.Entry()
        name_entry.set_placeholder_text("z.B. Meine Blockliste")
        name_entry.set_margin_top(12)
        name_entry.set_margin_bottom(6)
        name_entry.set_margin_start(12)
        name_entry.set_margin_end(12)
        
        # URL Eingabe
        url_entry = Gtk.Entry()
        url_entry.set_placeholder_text("https://example.com/blocklist.txt")
        url_entry.set_margin_top(6)
        url_entry.set_margin_bottom(12)
        url_entry.set_margin_start(12)
        url_entry.set_margin_end(12)
        
        content_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        content_box.append(name_entry)
        content_box.append(url_entry)
        
        dialog.set_extra_child(content_box)
        
        def on_response(d, response):
            if response == "add":
                name = name_entry.get_text().strip()
                url = url_entry.get_text().strip()
                
                if not name or not url:
                    self.parent_window.show_info("Fehler", "Bitte Name und URL eingeben!")
                    return
                
                if not url.startswith(('http://', 'https://')):
                    self.parent_window.show_info("Fehler", "Bitte eine gültige URL eingeben!")
                    return
                
                if name in self.app.user_lists:
                    self.parent_window.show_info("Fehler", "Eine Liste mit diesem Namen existiert bereits!")
                    return
                
                self.app.add_user_list(name, url)
                self.refresh_list()
                self.parent_window.show_info("Erfolg", f"Blockliste '{name}' wurde hinzugefügt!")
        
        dialog.connect("response", on_response)
        dialog.present(self)
        GLib.timeout_add(100, lambda: (name_entry.grab_focus(), False)[1])

    def on_delete_list(self, name):
        """Löscht eine Benutzerliste"""
        dialog = Adw.AlertDialog(
            heading="Blockliste entfernen?",
            body=f"Möchten Sie die Liste '{name}' wirklich entfernen?"
        )
        dialog.add_response("cancel", "Abbrechen")
        dialog.add_response("delete", "Entfernen")
        dialog.set_response_appearance("delete", Adw.ResponseAppearance.DESTRUCTIVE)
        dialog.set_default_response("cancel")
        
        def on_response(d, response):
            if response == "delete":
                self.app.remove_user_list(name)
                self.refresh_list()
                self.parent_window.show_info("Erfolg", f"Blockliste '{name}' wurde entfernt!")
        
        dialog.connect("response", on_response)
        dialog.present(self)


class ManageCustomDialog(Adw.Window):
    def __init__(self, parent):
        super().__init__()
        self.parent_window = parent
        self.app = parent.app

        self.set_title("Gesperrte Webseiten")
        self.set_default_size(600, 450)
        self.set_transient_for(parent)
