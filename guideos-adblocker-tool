            log.info("Hauptfenster existiert bereits, bringe es in den Vordergrund")
            self.main_window.present()
            return
        
        self.main_window = AdBlockerWindow(application=self)
        
        def backup_worker():
            if not os.path.exists(self.BACKUP_FILE):
                log.info("backup_worker: erstelle Backup via sudo")
                run_privileged(f'cp /etc/hosts {self.BACKUP_FILE}')
                log.info("backup_worker: Backup fertig")
            else:
                log.info("backup_worker: Backup existiert bereits")

        t = threading.Thread(target=backup_worker, name="BackupThread", daemon=True)
        t.start()
        
        self.main_window.present()
        log.info("show_main_window: present() aufgerufen")

