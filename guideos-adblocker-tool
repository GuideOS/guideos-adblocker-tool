        def do_authenticate():
            password = password_entry.get_text()
            if not password:
                return
            
            auth_btn.set_sensitive(False)
            auth_btn.set_label("Überprüfe...")
            cancel_btn.set_sensitive(False)
            status_label.set_text("")
            
            def auth_worker():
                try:
                    proc = subprocess.run(
                        ['sudo', '-S', '-v'],
                        input=password,
                        stdout=subprocess.PIPE,
                        stderr=subprocess.PIPE,
                        text=True
                    )
                    
                    if proc.returncode == 0:
                        log.info("Authentifizierung erfolgreich")
                        GLib.idle_add(auth_success)
                    else:
                        log.error(f"Authentifizierung fehlgeschlagen: {proc.stderr}")
                        GLib.idle_add(auth_failed, "Falsches Passwort oder keine Berechtigung")
                        
                except Exception as e:
                    log.error(f"Auth Exception: {e}")
                    GLib.idle_add(auth_failed, str(e))
            
