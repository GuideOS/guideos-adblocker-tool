def run_privileged(command):
    """
    Führt einen Shell-Befehl mit sudo aus.
    Nutzt das bereits gecachte Passwort (einmalige Eingabe zu Beginn).
    """
    log.info(f"run_privileged: {command}")
    
    try:
        # sudo ohne Passwortabfrage (weil wir vorher sudo -v gemacht haben)
        result = subprocess.run(
            ['sudo', 'bash', '-c', command],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            timeout=60
        )
        
        if result.returncode != 0:
            log.error(f"Befehl fehlgeschlagen (rc={result.returncode}): {result.stderr}")
            
            # Prüfe ob es an fehlenden Rechten liegt
            if "sudo: a password is required" in result.stderr or "Authentication failure" in result.stderr:
                log.error("Authentifizierung abgelaufen oder fehlgeschlagen")
                return 1, "", "AUTH_EXPIRED"
                
        return result.returncode, result.stdout, result.stderr
        
    except subprocess.TimeoutExpired:
        log.error(f"Timeout nach 60 Sekunden: {command}")
        return 1, "", "Timeout"
    except Exception as e:
        log.error(f"run_privileged Exception: {e}")
        return 1, "", str(e)


