    def load_user_lists(self):
        """Lädt benutzerdefinierte Blocklisten aus JSON-Datei"""
        if os.path.exists(self.USER_LISTS_FILE):
            try:
                with open(self.USER_LISTS_FILE, 'r') as f:
                    return json.load(f)
            except Exception as e:
                log.error(f"Fehler beim Laden der User-Lists: {e}")
                return {}
        return {}

    def save_user_lists(self):
        """Speichert benutzerdefinierte Blocklisten in JSON-Datei"""
        try:
            with open(self.USER_LISTS_FILE, 'w') as f:
                json.dump(self.user_lists, f, indent=2)
            log.info("User-Lists gespeichert")
        except Exception as e:
            log.error(f"Fehler beim Speichern der User-Lists: {e}")

    def add_user_list(self, name, url):
        """Fügt eine benutzerdefinierte Blockliste hinzu"""
        self.user_lists[name] = url
        self.save_user_lists()

    def remove_user_list(self, name):
        """Entfernt eine benutzerdefinierte Blockliste"""
        if name in self.user_lists:
            del self.user_lists[name]
            self.save_user_lists()

    def get_all_lists(self):
        """Gibt alle Blocklisten (vordefiniert + benutzerdefiniert) zurück"""
        all_lists = self.BLOCKLISTS.copy()
        all_lists.update(self.user_lists)
        return all_lists

